{% extends "README.j2" %}

{% block deprecation_notice -%}
{%- if deprecated %}
!!! danger "Deprecated"
    This image is no longer actively maintained or built.
{%- if deprecated.reason %}

    **Reason:** {{ deprecated.reason }}
{%- endif %}
{%- if deprecated.sunset_date %}

    **Sunset date:** {{ deprecated.sunset_date }}
{%- endif %}
{%- if deprecated.migration_guide %}

    **Migration:**

    {{ deprecated.migration_guide | indent(4) }}
{%- endif %}

{%- if deprecated.replacement %}
!!! tip "Use [{{ deprecated.replacement }}]({{ deprecated.replacement }}.md) instead"
    Migrate to **[{{ deprecated.replacement }}]({{ deprecated.replacement }}.md)**, which replaces this image.

{% endif -%}
{% endif -%}
{%- endblock %}

{% block prerequisites -%}
!!! failure "Root Privileges Required"
    **Podman on FreeBSD currently requires root.** All commands must be run as root (or via `doas`/`sudo`).
{%- if mlock %}

!!! warning ".NET Memory Locking (mlock)"
    This application requires `--annotation 'org.freebsd.jail.allow.mlock=true'` (Requires [patched ocijail](/guides/ocijail-patch/)).
{%- endif -%}
{%- if sysvipc %}

!!! warning "System V IPC Required"
    This application requires `--annotation 'org.freebsd.jail.allow.sysvipc=true'` for shared memory access (Requires [patched ocijail](/guides/ocijail-patch/)).
{%- endif %}

Before deploying, ensure your host environment is ready. See the [Quick Start Guide](../guides/quick-start.md) for host setup instructions.
{% endblock %}

{% block deployment_tabs %}
{%- set port_var = "@" ~ name.upper().replace("-", "_") ~ "_PORT@" %}
=== ":material-docker: Podman Compose"

    ```yaml
    {{ compose_snippet(port_var) | indent(4) }}
    ```

{% if appjail_enabled %}
=== ":appjail-appjail: AppJail Director"

    {{ appjail_snippet() | indent(4) }}

{% endif %}
=== ":material-console: Podman CLI"

    ```bash
    {{ cli_snippet(port_var) | indent(4) }}
    ```

=== ":simple-ansible: Ansible"

    ```yaml
    {{ ansible_snippet(port_var) | indent(4) }}
    ```
{% endblock %}

{% block interactive_config %}

### Interactive Configuration

<div class="placeholder-settings-panel"></div>
{% endblock %}

{% block implementation_details %}
!!! info "Implementation Details"

    - **Architectures:** {{ architectures | default(['amd64']) | join(', ') }}
    - **User:** `{{ user }}` (UID/GID set via [PUID/PGID](../guides/permissions.md)). Defaults to `1000:1000`.
    - **Base:** Built on `@REGISTRY@/base` (FreeBSD 15.0).
{% endblock %}


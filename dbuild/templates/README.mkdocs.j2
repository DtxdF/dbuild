{% extends "README.j2" %}

{% block frontmatter -%}
---
title: "Run {{ title }} on FreeBSD — Native OCI Container"
description: "{{ description }} Built natively for FreeBSD with s6 supervision, PUID/PGID support, and CI-tested on every release."
---
{% endblock %}

{% block deprecation_notice -%}
{%- if deprecated %}
!!! danger "Deprecated"
    This image is no longer actively maintained or built.
{%- if deprecated.reason %}

    **Reason:** {{ deprecated.reason }}
{%- endif %}
{%- if deprecated.sunset_date %}

    **Sunset date:** {{ deprecated.sunset_date }}
{%- endif %}
{%- if deprecated.migration_guide %}

    **Migration:**

    {{ deprecated.migration_guide | indent(4) }}
{%- endif %}

{%- if deprecated.replacement %}
!!! tip "Use [{{ deprecated.replacement }}]({{ deprecated.replacement }}.md) instead"
    Migrate to **[{{ deprecated.replacement }}]({{ deprecated.replacement }}.md)**, which replaces this image.

{%- elif deprecated.successor %}
!!! tip "Successor"
    See **[{{ deprecated.successor }}]({{ deprecated.successor }})** for an alternative.

{% endif %}
{% endif %}
{%- endblock %}

{% block screenshots %}
{% if screenshots %}
<section class="splide screenshot-carousel" aria-label="{{ title }} screenshots">
  <div class="splide__track">
    <ul class="splide__list">
{% for shot in screenshots %}
      <li class="splide__slide">
        <a href="{{ shot }}" class="glightbox" data-gallery="{{ name }}">
          <img src="{{ shot }}" loading="lazy" alt="{{ title }} screenshot {{ loop.index }}">
        </a>
      </li>
{% endfor %}
    </ul>
  </div>
</section>
{% endif %}
{% endblock %}

{% block header_meta %}
| | |
|---|---|
{%- if ports %}
| :material-lan-connect: **Port** | `{{ ports[0].port }}` |
{%- endif %}
| :material-docker: **Registry** | [`{{ registry }}/{{ name }}`](https://github.com/daemonless/{{ name }}/pkgs/container/{{ name }}) |
| :fontawesome-brands-github: **Daemonless** | [daemonless/{{ name }}](https://github.com/daemonless/{{ name }}) |
| :material-code-tags: **Source** | [{{ upstream_url | replace('https://github.com/', '') | replace('https://', '') | truncate(40, true, '…') }}]({{ upstream_url }}) |
{%- if web_url %}
| :material-web: **Website** | [{{ web_url | replace('https://', '') | replace('http://', '') | trim('/') }}]({{ web_url }}) |
{%- endif %}
{% endblock %}

{% block prerequisites -%}

!!! failure "Root Privileges Required"
    **Podman on FreeBSD currently requires root.** All commands must be run as root (or via `doas`/`sudo`).

Before deploying, ensure your host environment is ready. See the [Quick Start Guide](../guides/quick-start.md) for host setup instructions.
{% endblock %}

{% block deployment_tabs %}
{%- set port_var = "@" ~ name.upper().replace("-", "_") ~ "_PORT@" %}
{%- if image_class == "service" %}
=== ":material-docker: Podman Compose"

    ```yaml { data-zip-bundle="{{ name }}-podman" data-zip-filename="compose.yaml" }
    {{ compose_snippet(port_var) | indent(4) }}
    ```

{% if appjail_enabled %}
=== ":appjail-appjail: AppJail Director"

    {{ appjail_snippet() | indent(4) }}

{% endif %}
{%- endif %}
=== ":material-console: Podman CLI"

    ```bash { data-zip-bundle="{{ name }}-podman-cli" data-zip-filename="run.sh" }
    {{ cli_snippet(port_var) | indent(4) }}
    ```

{%- if image_class == "service" %}

=== ":simple-ansible: Ansible"

    ```yaml { data-zip-bundle="{{ name }}-ansible" data-zip-filename="{{ name }}-deploy.yaml" }
    {{ ansible_snippet(port_var) | indent(4) }}
    ```
{%- endif %}
{% endblock %}

{% block interactive_config %}
{%- if image_class == "service" %}

### Interactive Configuration

<div class="placeholder-settings-panel"></div>
{%- endif %}
{% endblock %}

{% block implementation_details %}
!!! info "Implementation Details"

    - **Architectures:** {{ architectures | default(['amd64']) | join(', ') }}
    - **User:** `{{ user }}` (UID/GID set via [PUID/PGID](../guides/permissions.md)). Defaults to `1000:1000`.
    - **Base:** Built on `@REGISTRY@/base` (FreeBSD 15.0).
{%- if mlock %}
    - **mlock:** Requires `--annotation 'org.freebsd.jail.allow.mlock=true'` ([ocijail 0.5.0+](/guides/ocijail-patch/))
{%- endif %}
{%- if sysvipc %}
    - **sysvipc:** Requires `--annotation 'org.freebsd.jail.allow.sysvipc=true'` ([ocijail 0.5.0+](/guides/ocijail-patch/))
{%- endif %}
{% endblock %}

{% block links %}
[Website]({{ web_url }}){ .md-button .md-button--primary }
[Source Code]({{ upstream_url }}){ .md-button }
{% endblock %}

{%- macro compose_snippet(port_var) -%}
services:
  {{ name }}:
    image: @REGISTRY@/{{ name }}:latest
    container_name: {{ name }}
{%- if env %}
    environment:
{%- for e in env %}
      - {{ e.name }}={{ e.placeholder if e.placeholder else e.default }}
{%- endfor %}
{%- endif %}
{%- if volumes %}
    volumes:
{%- for v in volumes %}
      - "{{ v.root_var ~ "/" if v.root_var else "" }}{{ v.placeholder if v.placeholder else v.source }}:{{ v.path }}"{{ " # optional" if v.optional else "" }}
{%- endfor %}
{%- endif %}
{%- if ports %}
    ports:
{%- for p in ports %}
{%- if loop.first %}
      - {{ port_var }}:{{ p.port }}
{%- else %}
      - {{ p.port }}:{{ p.port }}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- if mlock %}
    annotations:
      org.freebsd.jail.allow.mlock: "true"
{%- endif %}
{%- if healthcheck %}
    healthcheck:
      test: ["CMD", "{{ healthcheck }}"]
{%- endif %}
    restart: unless-stopped
{%- endmacro %}

{%- macro appjail_snippet() -%}
**.env**:

```
DIRECTOR_PROJECT={{ name }}
{%- for e in env %}
{%- if e.placeholder %}
{{ e.name }}={{ e.placeholder }}
{%- endif %}
{%- endfor %}
```

**appjail-director.yml**:

```yaml
options:
{%- if appjail and appjail.director and appjail.director.options %}
{%- for opt in appjail.director.options %}
  - {{ opt }}
{%- endfor %}
{%- else %}
  - virtualnet: ':<random> default'
  - nat:
{%- endif %}
services:
  {{ name }}:
    name: {{ name | replace("-", "_") }}
    options:
      - from: @REGISTRY@/{{ name }}:latest
{%- if appjail and appjail.makejail and appjail.makejail.options %}
{%- for opt in appjail.makejail.options %}
      - {{ opt }}
{%- endfor %}
{%- endif %}
{%- if env %}
    oci:
      environment:
{%- for e in env %}
        - {{ e.name }}: "!ENV '${ {{ e.name }} }'"
{%- endfor %}
{%- endif %}

{%- if volumes %}
    volumes:
{%- for v in volumes %}
      - {{ v.placeholder | replace("@", "") | replace("_PATH", "") | lower }}: {{ v.path }}
{%- endfor %}
{%- endif %}
{%- if appjail and appjail.depends_on %}
{%- for dep in appjail.depends_on %}
  {{ dep.name }}:
    name: {{ dep.name | replace("-", "_") }}
    options:
      - from: {{ dep.image }}
{%- if dep.template %}
      - template: !ENV '${PWD}/{{ dep.template }}'
{%- endif %}
{%- if dep.env %}
    oci:
      environment:
{%- for k, v in dep.env.items() %}
        - {{ k }}: "{{ v }}"
{%- endfor %}
{%- endif %}

{%- if dep.volumes %}
    volumes:
{%- for k, v in dep.volumes.items() %}
      - {{ k }}: {{ v }}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- if volumes or (appjail and appjail.depends_on) %}
volumes:
{%- if volumes %}
{%- for v in volumes %}
  {{ v.placeholder | replace("@", "") | replace("_PATH", "") | lower }}:
    device: '{% if v.root_var %}@CONTAINER_CONFIG_ROOT@/{% endif %}{{ v.placeholder }}'
{%- endfor %}
{%- endif %}
{%- if appjail and appjail.depends_on %}
{%- for dep in appjail.depends_on %}
{%- if dep.volumes %}
{%- for vol_id, vol_path in dep.volumes.items() %}
  {{ vol_id }}:
    device: "!ENV '${ {{ vol_id.upper() }} _LOCATION}'"
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endif %}
```

**Makejail**:

```
OPTION container=boot args:--pull
```
{%- endmacro %}

{%- macro cli_snippet(port_var) -%}
podman run -d --name {{ name }} \
{%- for p in ports %}
{%- if loop.first %}
  -p {{ port_var }}:{{ p.port }} \
{%- else %}
  -p {{ p.port }}:{{ p.port }} \
{%- endif %}
{%- endfor %}
{%- if mlock %}
  --annotation 'org.freebsd.jail.allow.mlock=true' \
{%- endif %}
{%- if healthcheck %}
  --health-cmd {{ healthcheck }} \
{%- endif %}
{%- for e in env %}
  -e {{ e.name }}={{ e.placeholder if e.placeholder else e.default }} \
{%- endfor %}
{%- for v in volumes %}
  -v {{ v.root_var ~ "/" if v.root_var else "" }}{{ v.placeholder if v.placeholder else v.source }}:{{ v.path }}{{ " # optional" if v.optional else "" }} \
{%- endfor %}
  @REGISTRY@/{{ name }}:latest
{%- endmacro %}

{%- macro ansible_snippet(port_var) -%}
- name: Deploy {{ name }}
  containers.podman.podman_container:
    name: {{ name }}
    image: @REGISTRY@/{{ name }}:latest
    state: started
    restart_policy: always
{%- if env %}
    env:
{%- for e in env %}
      {{ e.name }}: "{{ e.placeholder if e.placeholder else e.default }}"
{%- endfor %}
{%- endif %}
{%- if ports %}
    ports:
{%- for p in ports %}
{%- if loop.first %}
      - "{{ port_var }}:{{ p.port }}"
{%- else %}
      - "{{ p.port }}:{{ p.port }}"
{%- endif %}
{%- endfor %}
{%- endif %}
{%- if volumes %}
    volumes:
{%- for v in volumes %}
      - "{{ v.root_var ~ "/" if v.root_var else "" }}{{ v.placeholder if v.placeholder else v.source }}:{{ v.path }}"{{ " # optional" if v.optional else "" }}
{%- endfor %}
{%- endif %}
{%- if mlock %}
    annotation:
      org.freebsd.jail.allow.mlock: "true"
{%- endif %}
{%- endmacro %}


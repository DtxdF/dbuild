{#- ==================================================================
    Logic — Resolve values based on render_mode (MkDocs vs GitHub)
    ================================================================== #}
{%- if render_mode == "mkdocs" %}
  {%- set reg_var = "@REGISTRY@" %}
  {%- set cfg_root = "@CONTAINER_CONFIG_ROOT@" %}
  {%- set port_var = "@" ~ name.upper().replace("-", "_") ~ "_PORT@" %}
{%- else %}
  {%- set reg_var = registry %}
  {%- set cfg_root = "/path/to/containers" %}
  {%- set port_var = ports[0].port if ports else "" %}
{%- endif -%}

{#- ==================================================================
    Macros — deployment snippets
    ================================================================== #}

{%- macro compose_snippet(override_port=None) -%}
services:
  {{ name }}:
    image: {{ reg_var }}/{{ name }}:latest
    container_name: {{ name }}
{%- if env %}
    environment:
{%- for e in env %}
      - {{ e.name }}={{ e.placeholder if (render_mode == "mkdocs" and e.placeholder) else e.default }}
{%- endfor %}
{%- endif %}
{%- if volumes %}
    volumes:
{%- for v in volumes %}
      - "{% if v.root_var %}{{ cfg_root }}/{% else %}/path/to/{% endif %}{{ v.placeholder if (render_mode == "mkdocs" and v.placeholder) else v.source }}:{{ v.path }}"{{ " # optional" if v.optional else "" }}
{%- endfor %}
{%- endif %}
{%- if ports %}
    ports:
{%- for p in ports %}
{%- if loop.first %}
      - {{ override_port if override_port else port_var }}:{{ p.port }}
{%- else %}
      - {{ p.port }}:{{ p.port }}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- if jail_allow %}
    annotations:
{%- for opt in jail_allow %}
      org.freebsd.jail.{{ opt }}: "true"
{%- endfor %}
{%- endif %}
{%- if healthcheck %}
    healthcheck:
      test: ["CMD", "{{ healthcheck }}"]
{%- endif %}
    restart: unless-stopped
{%- endmacro %}

{%- macro appjail_snippet() -%}
**.env**:

```
DIRECTOR_PROJECT={{ name }}
{%- for e in env %}
{{ e.name }}={{ e.placeholder if (render_mode == "mkdocs" and e.placeholder) else e.default }}
{%- endfor %}
```

**appjail-director.yml**:

```yaml
options:
{%- if appjail and appjail.director and appjail.director.options %}
{%- for opt in appjail.director.options %}
  - {{ opt }}
{%- endfor %}
{%- else %}
  - virtualnet: ':<random> default'
  - nat:
{%- endif %}
services:
  {{ name }}:
    name: {{ name | replace("-", "_") }}
    options:
      - container: 'boot args:--pull'
{%- if appjail and appjail.makejail and appjail.makejail.options %}
{%- for opt in appjail.makejail.options %}
{%- if opt is mapping %}
{%- for k, v in opt.items() %}
      - {{ k }}: "{{ v }}"
{%- endfor %}
{%- else %}
      - {{ opt }}
{%- endif %}
{%- endfor %}
{%- endif %}

{%- if env %}
    oci:
      user: root
      environment:
{%- for e in env %}
        - {{ e.name }}: !ENV '${{ '{' }}{{ e.name }}{{ '}' }}'
{%- endfor %}
{%- endif %}

{%- if volumes %}
    volumes:
{%- for v in volumes %}
      - {{ v.placeholder.replace("@", "") if (render_mode == "mkdocs" and v.placeholder) else v.source.replace("/", "_").replace(".", "_").strip("_") }}: {{ v.path }}
{%- endfor %}
{%- endif %}

{%- if appjail and appjail.depends_on %}
{%- for dep in appjail.depends_on %}
  {{ dep.name }}:
    name: {{ dep.name | replace("-", "_") }}
    options:
      - from: {{ dep.image }}
{%- if dep.template %}
      - template: !ENV '${PWD}/{{ dep.template }}'
{%- endif %}
{%- if dep.env %}
    oci:
      environment:
{%- for k, v in dep.env.items() %}
        - {{ k }}: "{{ v }}"
{%- endfor %}
{%- endif %}
{%- if dep.volumes %}
    volumes:
{%- for k, v in dep.volumes.items() %}
      - {{ k }}: {{ v }}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- endif %}

{%- if volumes or (appjail and appjail.depends_on) %}
volumes:
{%- if volumes %}
{%- for v in volumes %}
  {{ v.placeholder.replace("@", "") if (render_mode == "mkdocs" and v.placeholder) else v.source.replace("/", "_").replace(".", "_").strip("_") }}:
    device: '{% if v.root_var %}{{ cfg_root }}/{% endif %}{{ v.placeholder if (render_mode == "mkdocs" and v.placeholder) else v.source }}'
{%- endfor %}
{%- endif %}
{%- if appjail and appjail.depends_on %}
{%- for dep in appjail.depends_on %}
{%- if dep.volumes %}
{%- for vol_id, vol_path in dep.volumes.items() %}
  {{ vol_id }}:
    device: "!ENV '${ {{ vol_id.upper() }} _LOCATION}'"
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endif %}
```

**Makejail**:

```
ARG tag={{ default_tag }}

OPTION overwrite=force
OPTION from={{ reg_var }}/{{ name }}:${tag}
{%- for opt in jail_allow %}
SET {{ opt }}=1
{%- endfor %}
```
{%- endmacro %}

{%- macro cli_snippet(override_port=None) -%}
podman run -d --name {{ name }} \
{%- for p in ports %}
{%- if loop.first %}
  -p {{ override_port if override_port else port_var }}:{{ p.port }} \
{%- else %}
  -p {{ p.port }}:{{ p.port }} \
{%- endif %}
{%- endfor %}
{%- for opt in jail_allow %}
  --annotation 'org.freebsd.jail.{{ opt }}=true' \
{%- endfor %}
{%- if healthcheck %}
  --health-cmd {{ healthcheck }} \
{%- endif %}
{%- for e in env %}
  -e {{ e.name }}={{ e.placeholder if (render_mode == "mkdocs" and e.placeholder) else e.default }} \
{%- endfor %}
{%- for v in volumes %}
  -v {% if v.root_var %}{{ cfg_root }}/{% else %}/path/to/{% endif %}{{ v.placeholder if (render_mode == "mkdocs" and v.placeholder) else v.source }}:{{ v.path }}{{ " # optional" if v.optional else "" }} \
{%- endfor %}
  {{ reg_var }}/{{ name }}:latest
{%- endmacro %}

{%- macro ansible_snippet(override_port=None) -%}
- name: Deploy {{ name }}
  containers.podman.podman_container:
    name: {{ name }}
    image: {{ reg_var }}/{{ name }}:latest
    state: started
    restart_policy: always
{%- if env %}
    env:
{%- for e in env %}
      {{ e.name }}: "{{ e.placeholder if (render_mode == "mkdocs" and e.placeholder) else e.default }}"
{%- endfor %}
{%- endif %}
{%- if ports %}
    ports:
{%- for p in ports %}
{%- if loop.first %}
      - "{{ override_port if override_port else port_var }}:{{ p.port }}"
{%- else %}
      - "{{ p.port }}:{{ p.port }}"
{%- endif %}
{%- endfor %}
{%- endif %}
{%- if volumes %}
    volumes:
{%- for v in volumes %}
      - "{% if v.root_var %}{{ cfg_root }}/{% else %}/path/to/{% endif %}{{ v.placeholder if (render_mode == "mkdocs" and v.placeholder) else v.source }}:{{ v.path }}"{{ " # optional" if v.optional else "" }}
{%- endfor %}
{%- endif %}
{%- if jail_allow %}
    annotation:
{%- for opt in jail_allow %}
      org.freebsd.jail.{{ opt }}: "true"
{%- endfor %}
{%- endif %}
{%- endmacro -%}


{% if deployed is defined and deployed %}
## Images

| Status | Image | Tag | Version | CI/CD |
|:------:|-------|-----|---------|:-----:|
{%- set outdated_lookup = {} %}
{%- for item in outdated %}
{%- for update in item.updates %}
{%- set _ = outdated_lookup.update({(item.name, update.tag): update}) %}
{%- endfor %}
{%- endfor %}
{%- for name in deployed | sort %}
{%- set svc_deployed = deployed[name] %}
{%- set actions_url = 'https://github.com/daemonless/' ~ name ~ '/actions/workflows/build.yaml' %}
{%- for tag in ['pkg', 'pkg-latest', 'latest'] %}
{%- if (name, tag) in outdated_lookup %}
{%- set update = outdated_lookup[(name, tag)] %}
| :material-close-circle:{ .outdated } | [{{ name }}](images/{{ name }}.md) | {{ tag }} | {{ update.deployed }} → **{{ update.available | replace('v', '', 1) }}** | [:simple-githubactions:]({{ actions_url }}) |
{%- elif tag in svc_deployed %}
| :material-check-circle:{ .current } | [{{ name }}](images/{{ name }}.md) | {{ tag }} | {{ svc_deployed[tag] }} | [:simple-githubactions:]({{ actions_url }}) |
{%- endif %}
{%- endfor %}
{%- endfor %}
{% endif %}

